# Anthropic (기존)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI Vision — 사진 Scene 분석
OPENAI_API_KEY=sk-...
OPENAI_SCENE_MODEL=gpt-4.1-mini
OPENAI_SCENE_MODEL_HIGH=gpt-4.1

# 메모 — 일반 텍스트·펜 템플릿·음성 AI 요약 및 이미지 정돈
OPENAI_MEMO_MODEL=gpt-4.1-mini
OPENAI_MEMO_VISION_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_IMAGE_MODEL=gpt-image-2

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://...supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...

# 캘린더 일정 알람 — Vercel Cron + Telegram
CRON_SECRET=...
TELEGRAM_BOT_TOKEN=...
TELEGRAM_ALLOWED_USER_ID=...
# 선택: 일정 알람을 별도 채팅으로 보낼 때만 설정 (미설정 시 ALLOWED_USER_ID 사용)
TELEGRAM_NOTIFICATION_CHAT_ID=...

# 대표자 전용 Olivia 카카오 AI 비서
# 32바이트 이상의 임의 문자열. 연결 식별자와 OAuth 토큰 암호화에 사용.
ASSISTANT_ENCRYPTION_KEY=...
# 카카오 챗봇 스킬 URL에 Olivia가 요구하는 별도 비밀 헤더 값
KAKAO_SKILL_SECRET=...
KAKAO_BOT_ID=...
KAKAO_REST_API_KEY=...
KAKAO_ADMIN_KEY=...
KAKAO_CHANNEL_PUBLIC_ID=...
# 카카오 i 오픈빌더에서 Callback API 사용 승인을 받은 뒤 true
KAKAO_CALLBACK_ENABLED=false
# 카카오 Event API에 등록한 이벤트 이름
KAKAO_BRIEFING_EVENT_NAME=olivia_briefing
KAKAO_NOTIFICATION_EVENT_NAME=olivia_notification

# 대표자 Gmail 조회·요약·답장 초안
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# 배포 주소. 카카오 음성 입력 링크와 Google OAuth callback 생성에 사용.
NEXT_PUBLIC_BASE_URL=https://your-domain.example.com
